{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      {
        "source": "/api/**",
        "function": {
          "id": "api",
          "codebase": "dcpkode9"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}