{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user identifiers and profiles synced after SSO",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "phone": { "type": "string" },
        "preferredDevice": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "RepairTicket": {
      "title": "Repair Ticket",
      "description": "Enterprise-level service tickets created in SpokaneWA laboratory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "companyName": { "type": "string" },
        "device": { "type": "string" },
        "issueType": { "type": "string" },
        "status": { "type": "string" },
        "quotedPrice": { "type": "number" },
        "tax": { "type": "number" },
        "discount": { "type": "number" },
        "total": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "internalNotes": { "type": "string" }
      },
      "required": ["id", "customerName", "device", "issueType", "status", "total", "createdAt"]
    },
    "HighPriorityLead": {
      "title": "High Priority Lead",
      "description": "Stores Tier 3 hardware escalation details for manual technician callback",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "deviceModel": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in_progress", "contacted", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["id", "customerName", "phone", "deviceModel", "status", "createdAt", "userId"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile information"
    },
    "tickets/{ticketId}": {
      "schema": "RepairTicket",
      "description": "Comprehensive customer repair records synced with local Spokane WA sales details"
    },
    "high-priority-leads/{leadId}": {
      "schema": "HighPriorityLead",
      "description": "Hot leads representing complex repairs routed to manual technician callback queues"
    }
  }
}
